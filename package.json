{
  "name": "nwn-bustimes",
  "description": "Real-time bus departures and connections for North West Norfolk",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npx concurrently \"vite --port=3000 --host=0.0.0.0\" \"node --env-file=.env --import=tsx server.ts\"",
    "dev:server": "node --env-file=.env --import=tsx watch server.ts",
    "build": "vite build",
    "start": "node --env-file=.env --import=tsx server.ts",
    "preview": "npm run build && npm run start",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "@google/genai": "^1.48.0",
    "cheerio": "^1.2.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^7.3.2"
  }
}
